{
  "name": "walls-monorepo",
  "private": true,
  "packageManager": "pnpm@10.12.1",
  "scripts": {
    "dev": "turbo dev",
    "dev:public": "turbo dev --filter=public-site",
    "dev:adpilot": "turbo dev --filter=adpilot",
    "dev:portal": "turbo dev --filter=portal",
