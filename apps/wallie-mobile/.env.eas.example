# EAS Build env — mobile only. Copy to .env.eas and fill production values, or run:
#   pnpm eas:env:sync && pnpm eas:env:push:preview
#
# Do not commit .env.eas (gitignored).

NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Production Wallie web (voice/transcribe). Do not use localhost for EAS builds.
NEXT_PUBLIC_WALLIE_URL=https://wallie.walls.agency
# Optional explicit mobile override (same as above if unset in app.config)
NEXT_PUBLIC_WALLIE_MOBILE_WEB_URL=https://wallie.walls.agency

# Remote wallie-api (Hetzner)
NEXT_PUBLIC_WALLIE_API_URL=https://datalabs.wallsentertainment.com
